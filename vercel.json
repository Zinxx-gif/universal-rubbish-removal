    },
    {
      "source": "/rubbish-removal-waterford/",
      "destination": "/rubbish-removal-kilkenny/",
      "permanent": true
    },
    {
      "source": "/rubbish-removal-wexford",
      "destination": "/rubbish-removal-kilkenny",
